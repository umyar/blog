---
interface Props {
  currentLang: string;
  slug: string;
  availableLangs: string[];
}

const { currentLang, slug, availableLangs } = Astro.props;

const labels: Record<string, string> = { ru: 'RU', en: 'EN', pt: 'PT' };
---

<nav class="flex gap-3 text-xs font-bold tracking-wider" aria-label="Language">
  {
    availableLangs.map((lang) => (
      <a
        href={`/posts/${lang}/${slug}`}
        class:list={[
          'transition',
          lang === currentLang
            ? 'gradient-text'
            : 'text-zinc-400 hover:text-zinc-700 dark:text-zinc-500 dark:hover:text-zinc-300',
        ]}
        aria-current={lang === currentLang ? 'page' : undefined}
      >
        {labels[lang] ?? lang.toUpperCase()}
      </a>
    ))
  }
</nav>

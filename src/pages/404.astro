---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — umyar blog" description="Page not found.">
  <div class="mx-auto w-full max-w-7xl px-6 sm:px-14 lg:px-24">
    <div class="mx-auto flex max-w-2xl flex-col items-center py-24 text-center">
      <p class="gradient-text text-5xl font-bold tracking-tight sm:text-7xl">404</p>
      <h1 class="mt-6 text-2xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100">
        Page not found
      </h1>
      <p class="mt-4 text-base text-zinc-600 dark:text-zinc-400">
        Sorry, we couldn't find the page you're looking for.
      </p>
      <a
        href="/"
        class="mt-8 text-sm font-medium text-zinc-500 transition hover:gradient-text dark:text-zinc-400"
      >
        ← Back to articles
      </a>
    </div>
  </div>
</BaseLayout>

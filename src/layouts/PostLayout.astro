---
import BaseLayout from './BaseLayout.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import FontSizeSelector from '../components/FontSizeSelector.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  slug?: string;
  availableLangs?: string[];
  date?: string;
  cover?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  lang = 'en',
  slug = '',
  availableLangs = [],
  date,
  cover,
  jsonLd,
} = Astro.props;

// Split the title so emoji render in their native colors instead of being
// clipped to the gradient (background-clip: text makes everything transparent).
const titleParts: { text: string; emoji: boolean }[] = [];
{
  const emojiRe = /\p{Extended_Pictographic}(‍\p{Extended_Pictographic})*️?/gu;
  let last = 0;
  for (const m of title.matchAll(emojiRe)) {
    if (m.index! > last) titleParts.push({ text: title.slice(last, m.index), emoji: false });
    titleParts.push({ text: m[0], emoji: true });
    last = m.index! + m[0].length;
  }
  if (last < title.length) titleParts.push({ text: title.slice(last), emoji: false });
}

const formattedDate = date
  ? new Date(date).toLocaleDateString(lang === 'ru' ? 'ru-RU' : lang === 'pt' ? 'pt-BR' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout title={title} description={description} lang={lang} ogType="article" ogImage={cover}>
  <Fragment slot="head">
    <slot name="head" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script is:inline>
      (function () {
        var size = localStorage.getItem('blog-font-size') || '18';
        document.documentElement.style.setProperty('--prose-font-size', size + 'px');
      })();
    </script>
  </Fragment>

  <div class="mx-auto mt-16 w-full max-w-7xl px-6 sm:px-14 lg:px-24">
    <div class="mx-auto max-w-2xl">
      <!-- Back button -->
      <a
        href="/"
        aria-label="Back to articles"
        class="group mb-8 flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 transition hover:ring-zinc-900/10 dark:border dark:border-zinc-700/50 dark:bg-zinc-800 dark:ring-0 dark:hover:border-zinc-700"
      >
        <svg
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
          class="h-4 w-4 stroke-zinc-500 transition group-hover:stroke-zinc-700 dark:stroke-zinc-500 dark:group-hover:stroke-zinc-400"
        >
          <path
            d="M7.25 11.25 3.75 8m0 0 3.5-3.25M3.75 8h8.5"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>

      <article>
        <header class="flex flex-col">
          <div class="order-first mb-4 flex items-center justify-between gap-4">
            {formattedDate ? (
              <time
                class="flex items-center text-base text-zinc-400 dark:text-zinc-500"
                datetime={date}
              >
                <span class="h-4 w-0.5 rounded-full bg-gradient-to-b from-grad-from to-grad-to" />
                <span class="ml-3">{formattedDate}</span>
              </time>
            ) : (
              <span />
            )}
            {availableLangs.length > 1 && (
              <LanguageSwitcher currentLang={lang} slug={slug} availableLangs={availableLangs} />
            )}
          </div>
          <h1 class="gradient-text text-4xl font-bold tracking-tight text-balance sm:text-5xl leading-[1.15]">
            {titleParts.map((part) => (part.emoji ? <span class="emoji">{part.text}</span> : part.text))}
          </h1>
          {cover && <img class="mt-8 w-full rounded-2xl" src={cover} alt="" />}
        </header>

        <slot name="audio" />

        <div class="mt-6 flex items-center justify-end">
          <FontSizeSelector />
        </div>

        <div
          class="prose prose-zinc dark:prose-invert mt-8 max-w-none prose-a:font-medium prose-a:underline prose-img:rounded-2xl"
          style="font-size: var(--prose-font-size, 18px);"
        >
          <slot />
        </div>

        <slot name="comments" />
      </article>
    </div>
  </div>
</BaseLayout>
